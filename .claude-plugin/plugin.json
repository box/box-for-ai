{
  "name": "box",
  "description": "Box Plugin for Claude Code to help with Box Platform integrations including content workflows, shared links, webhooks, metadata, and Box AI retrieval.",
  "version": "1.0.0",
  "author": {
    "name": "Box"
  },
  "keywords": ["box", "content", "cloud-storage", "file-management", "collaboration"],
  "license": "MIT",
  "repository": "https://github.com/box/box-for-ai",
  "mcpServers": {
    "box": {
      "url": "https://mcp.box.com",
      "auth": {
        "CLIENT_ID": "${BOX_CLIENT_ID}",
        "CLIENT_SECRET": "${BOX_CLIENT_SECRET}"
      }
    }
  }
}
